<Window x:Class="Tenurix.Management.Views.CreateEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Employee"
        Width="520" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height"      Value="40"/>
            <Setter Property="Padding"     Value="12,0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Background"  Value="{StaticResource Panel2}"/>
            <Setter Property="Foreground"  Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,0,0,14"/>
        </Style>
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="{StaticResource Panel}" CornerRadius="16" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel>
                    <TextBlock Text="Create New Employee" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock Text="Fill in the details below to add a team member."
                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Form -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="FULL NAME" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="FullNameBox" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="EMAIL" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="MOBILE NUMBER" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="PhoneBox" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="ADDRESS" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="AddressBox" Style="{StaticResource FormInput}"/>

                        <TextBlock Text="POSITION" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="RoleBox" Height="40" Margin="0,0,0,14" FontSize="13">
                            <ComboBoxItem Content="Staff"/>
                            <ComboBoxItem Content="TeamLead"/>
                            <ComboBoxItem Content="AssistantManager"/>
                        </ComboBox>

                        <TextBlock Text="TEMPORARY PASSWORD" Style="{StaticResource FormLabel}"/>
                        <PasswordBox x:Name="TempPassBox" Height="40" Margin="0,0,0,10"
                                     Padding="12,0" FontSize="13"
                                     Background="{StaticResource Panel2}"
                                     BorderBrush="{StaticResource Border}" BorderThickness="1"/>

                        <TextBlock x:Name="ErrorText" Foreground="{StaticResource Danger}"
                                   TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelBtn" Grid.Column="0" Content="Cancel"
                            Style="{StaticResource RoundBtn}"
                            Background="{StaticResource Panel2}"
                            Foreground="{StaticResource Text}"
                            Click="Cancel_Click"/>

                    <Button x:Name="CreateBtn" Grid.Column="2" Content="Create Employee"
                            Style="{StaticResource RoundBtn}"
                            Background="{StaticResource Accent}"
                            Foreground="White"
                            Click="Create_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

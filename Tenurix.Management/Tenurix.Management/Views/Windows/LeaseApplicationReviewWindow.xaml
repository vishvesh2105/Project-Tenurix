<Window x:Class="Tenurix.Management.Views.Windows.LeaseApplicationReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Review Lease Application"
        MinWidth="700" MinHeight="550" Width="880" Height="720"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Foreground"  Value="{StaticResource Text}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="CardSection" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource Panel}"/>
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Padding"        Value="16"/>
            <Setter Property="Margin"         Value="0,0,0,12"/>
        </Style>
        <Style x:Key="ActBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Lease Application Review" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource Text}"/>
                <TextBlock Text="Review the applicant's details and approve or reject." FontSize="13"
                           Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" x:Name="StatusBadge" CornerRadius="8" Padding="14,6"
                    Background="{StaticResource AccentSoft}" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="Pending" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}"/>
            </Border>
            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}"
                    Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0"
                    Click="CloseButton_Click" ToolTip="Close" Padding="6" Panel.ZIndex="10"
                    Grid.ColumnSpan="2"/>
        </Grid>

        <!-- Body -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Applicant Info -->
                <Border Style="{StaticResource CardSection}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                                Background="{StaticResource AccentSoft}" Margin="0,0,16,0"
                                VerticalAlignment="Top">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="26"
                                       Foreground="{StaticResource Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="APPLICANT" Style="{StaticResource DetailLabel}"/>
                            <TextBlock x:Name="ApplicantText" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text}"/>
                            <TextBlock x:Name="ApplicantEmailText" Style="{StaticResource DetailValue}"
                                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Personal Details -->
                <Border Style="{StaticResource CardSection}">
                    <StackPanel>
                        <TextBlock Text="PERSONAL INFORMATION" Style="{StaticResource DetailLabel}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="PHONE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="PhoneText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DATE OF BIRTH" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="DobText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="CURRENT ADDRESS" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="CurrentAddressText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Employment & Income -->
                <Border Style="{StaticResource CardSection}">
                    <StackPanel>
                        <TextBlock Text="EMPLOYMENT &amp; INCOME" Style="{StaticResource DetailLabel}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="EMPLOYMENT STATUS" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="EmploymentStatusText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ANNUAL INCOME" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="IncomeText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="EMPLOYER" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="EmployerText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="JOB TITLE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="JobTitleText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Household -->
                <Border Style="{StaticResource CardSection}">
                    <StackPanel>
                        <TextBlock Text="HOUSEHOLD" Style="{StaticResource DetailLabel}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="OCCUPANTS" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="OccupantsText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PETS" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="PetsText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="PET DETAILS" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="PetDetailsText" Style="{StaticResource DetailValue}"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Emergency Contact & Reference -->
                <Border Style="{StaticResource CardSection}">
                    <StackPanel>
                        <TextBlock Text="EMERGENCY CONTACT" Style="{StaticResource DetailLabel}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="NAME" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="EmergencyNameText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PHONE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="EmergencyPhoneText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="RELATIONSHIP" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="EmergencyRelationText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Margin="0,14,0,14"/>

                        <TextBlock Text="REFERENCE" Style="{StaticResource DetailLabel}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="NAME" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="RefNameText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PHONE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="RefPhoneText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="RELATIONSHIP" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="RefRelationText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Application Details -->
                <Border Style="{StaticResource CardSection}">
                    <StackPanel>
                        <TextBlock Text="LEASE DETAILS" Style="{StaticResource DetailLabel}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="PROPERTY" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="ListingText" Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="START DATE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="StartDateText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="END DATE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="EndDateText" Style="{StaticResource DetailValue}"/>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Margin="0,14,0,14"/>

                        <TextBlock Text="ADDITIONAL NOTES" Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="NotesText" Style="{StaticResource DetailValue}"
                                   LineHeight="22" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Rejection Reason Box -->
                <Border Style="{StaticResource CardSection}">
                    <StackPanel>
                        <TextBlock Text="REJECTION REASON (required only for reject)" Style="{StaticResource DetailLabel}"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="ReasonBox" Height="44" Padding="12,0"
                                 VerticalContentAlignment="Center" FontSize="13"
                                 ToolTip="Enter a reason if rejecting this application"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Footer -->
        <Border Grid.Row="3" Background="{StaticResource Panel}" CornerRadius="12"
                Padding="16,14" Margin="0,0,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reject Application" Width="170" Height="42" Margin="0,0,10,0"
                        Style="{StaticResource ActBtn}"
                        Background="{StaticResource DangerSoft}"
                        Foreground="{StaticResource Danger}"
                        Padding="16,0"
                        Click="Reject_Click"/>
                <Button Content="Approve Application" Width="180" Height="42"
                        Style="{StaticResource ActBtn}"
                        Background="{StaticResource SuccessSoft}"
                        Foreground="{StaticResource Success}"
                        Padding="16,0"
                        Click="Approve_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>

<Page x:Class="Tenurix.Management.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource Panel}"/>
            <Setter Property="CornerRadius"   Value="14"/>
            <Setter Property="Padding"        Value="20,16"/>
        </Style>
        <Style x:Key="IconBox" TargetType="Border">
            <Setter Property="Width"          Value="42"/>
            <Setter Property="Height"         Value="42"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource Panel}"/>
            <Setter Property="CornerRadius"   Value="14"/>
        </Style>
        <Style x:Key="PeekBtn" TargetType="Button">
            <Setter Property="Background"     Value="{StaticResource AccentSoft}"/>
            <Setter Property="Foreground"     Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"        Value="10,4"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- Page Title -->
            <DockPanel Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock Text="Overview of pending work and recent activity."
                               FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>
                <TextBlock x:Name="LastUpdated" FontSize="11" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- Stat Cards -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Pending Submissions -->
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PENDING SUBMISSIONS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="PropCountText" Text="0" FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource Text}" Margin="0,4,0,0"/>
                            <TextBlock Text="Properties to review" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource IconBox}" Background="#EFF6FF">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F1;" FontSize="20"
                                       Foreground="{StaticResource Accent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Pending Lease Apps -->
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PENDING LEASE APPS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="LeaseCountText" Text="0" FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource Text}" Margin="0,4,0,0"/>
                            <TextBlock Text="Applications to process" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource IconBox}" Background="#F0FDF4">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="20"
                                       Foreground="{StaticResource Success}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Open Issues -->
                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="OPEN ISSUES" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="IssueCountText" Text="0" FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource Text}" Margin="0,4,0,0"/>
                            <TextBlock Text="Maintenance issues filed" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource IconBox}" Background="#FEF2F2">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="20"
                                       Foreground="{StaticResource Danger}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Active Employees -->
                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ACTIVE EMPLOYEES" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="EmpCountText" Text="0" FontSize="34" FontWeight="Bold"
                                       Foreground="{StaticResource Text}" Margin="0,4,0,0"/>
                            <TextBlock Text="Staff on the team" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource IconBox}" Background="#FFF7ED">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="20"
                                       Foreground="#C2410C"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Recent Sections Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Property Submissions -->
                <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <Border Padding="16,14" BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="Recent Submissions" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                <TextBlock Text="Pending landlord submissions" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl x:Name="RecentPropsGrid" Margin="8,6,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Panel2}" CornerRadius="10"
                                            Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding LandlordName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Address}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="View" Style="{StaticResource PeekBtn}"
                                                    Height="28" Margin="8,0,0,0" Click="ViewProp_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Recent Lease Applications -->
                <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <Border Padding="16,14" BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="Recent Applications" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                <TextBlock Text="Pending tenant applications" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl x:Name="RecentAppsGrid" Margin="8,6,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Panel2}" CornerRadius="10"
                                            Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ApplicantName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ListingTitle}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="View" Style="{StaticResource PeekBtn}"
                                                    Height="28" Margin="8,0,0,0" Click="ViewApp_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Recent Issues -->
                <Border Grid.Column="4" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <Border Padding="16,14" BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="Recent Issues" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                <TextBlock Text="Active maintenance requests" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ItemsControl x:Name="RecentIssuesGrid" Margin="8,6,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Panel2}" CornerRadius="10"
                                            Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FiledByName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding PropertyAddress}" FontSize="11"
                                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <!-- Status badge -->
                                            <Border x:Name="sbadge" Grid.Column="1" CornerRadius="10" Padding="8,3"
                                                    Background="#FEF2F2" VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock x:Name="stxt" Text="{Binding Status}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Danger}"/>
                                            </Border>
                                            <Button Grid.Column="2" Content="View" Style="{StaticResource PeekBtn}"
                                                    Height="28" Margin="6,0,0,0" Click="ViewIssue_Click"/>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Resolved">
                                            <Setter TargetName="sbadge" Property="Background" Value="#F0FDF4"/>
                                            <Setter TargetName="stxt"  Property="Foreground" Value="#15803D"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                            <Setter TargetName="sbadge" Property="Background" Value="#FFFBEB"/>
                                            <Setter TargetName="stxt"  Property="Foreground" Value="#D97706"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>
    </ScrollViewer>
    <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
        <TextBlock Text="Loading..." FontSize="14" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
    </Border>
    </Grid>
</Page>

<Window x:Class="Tenurix.Management.Views.VerificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tenurix — Verify Your Identity"
        Width="500" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VerifyBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource Border}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="36,0">

            <!-- Logo -->
            <Image Source="pack://application:,,,/Assets/Branding/tenurix_logoA.png"
                   Height="70" Stretch="Uniform" Margin="0,0,0,6"/>

            <TextBlock Text="Management Portal"
                       Foreground="{StaticResource TextMuted}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Verification Card -->
            <Border Background="{StaticResource Panel}" CornerRadius="16" Padding="28,24">
                <StackPanel>
                    <TextBlock Text="Verify Your Identity" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" Margin="0,0,0,6"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="SubTitle" TextWrapping="Wrap" FontSize="13"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,12"
                               Text="We've sent a verification code to your email"/>

                    <TextBlock x:Name="EmailDisplay" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- 6 Code Boxes -->
                    <UniformGrid Columns="6" HorizontalAlignment="Center" Width="330" Margin="0,0,0,6">
                        <TextBox x:Name="Code1" Style="{StaticResource CodeBox}" Margin="4,0"
                                 TextChanged="Code_TextChanged" PreviewKeyDown="Code_PreviewKeyDown"
                                 GotFocus="Code_GotFocus"/>
                        <TextBox x:Name="Code2" Style="{StaticResource CodeBox}" Margin="4,0"
                                 TextChanged="Code_TextChanged" PreviewKeyDown="Code_PreviewKeyDown"
                                 GotFocus="Code_GotFocus"/>
                        <TextBox x:Name="Code3" Style="{StaticResource CodeBox}" Margin="4,0"
                                 TextChanged="Code_TextChanged" PreviewKeyDown="Code_PreviewKeyDown"
                                 GotFocus="Code_GotFocus"/>
                        <TextBox x:Name="Code4" Style="{StaticResource CodeBox}" Margin="4,0"
                                 TextChanged="Code_TextChanged" PreviewKeyDown="Code_PreviewKeyDown"
                                 GotFocus="Code_GotFocus"/>
                        <TextBox x:Name="Code5" Style="{StaticResource CodeBox}" Margin="4,0"
                                 TextChanged="Code_TextChanged" PreviewKeyDown="Code_PreviewKeyDown"
                                 GotFocus="Code_GotFocus"/>
                        <TextBox x:Name="Code6" Style="{StaticResource CodeBox}" Margin="4,0"
                                 TextChanged="Code_TextChanged" PreviewKeyDown="Code_PreviewKeyDown"
                                 GotFocus="Code_GotFocus"/>
                    </UniformGrid>

                    <!-- Attempts remaining -->
                    <TextBlock x:Name="AttemptsText" Visibility="Collapsed"
                               Foreground="#D97706" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorText" Foreground="{StaticResource Danger}"
                               Margin="0,8,0,0" TextWrapping="Wrap" FontSize="13"
                               HorizontalAlignment="Center"/>

                    <!-- Verify Button -->
                    <Button x:Name="VerifyBtn" Content="Verify"
                            Style="{StaticResource VerifyBtn}"
                            Margin="0,18,0,0"
                            Click="Verify_Click"/>

                    <!-- Resend Timer -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                        <TextBlock x:Name="ResendLabel"
                                   Foreground="{StaticResource TextMuted}" FontSize="13"
                                   Text="Resend code in "/>
                        <TextBlock x:Name="TimerText"
                                   Foreground="{StaticResource Accent}" FontSize="13"
                                   FontWeight="SemiBold" Text="2:00"/>
                    </StackPanel>

                    <Button x:Name="ResendBtn" Content="Resend Code"
                            Visibility="Collapsed"
                            Foreground="{StaticResource Accent}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand" Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            Click="Resend_Click"/>

                    <!-- Back to login -->
                    <Button Content="Back to Sign In"
                            Foreground="{StaticResource TextMuted}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="12" Cursor="Hand" Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Click="BackToLogin_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>

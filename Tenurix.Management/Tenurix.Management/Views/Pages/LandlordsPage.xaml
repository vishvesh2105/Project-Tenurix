<Page x:Class="Tenurix.Management.Views.Pages.LandlordsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <!-- Rounded button style -->
        <Style x:Key="LlBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Landlord search result card item -->
        <Style x:Key="LlResultItem" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="10"
                                Padding="14,10" Margin="4,2" Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Panel2}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section expander style -->
        <Style x:Key="SectionExpander" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="IsExpanded" Value="False"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel>
            <TextBlock Text="Landlord Portfolio" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Text="Search landlords and review their properties, listings, and leases."
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search Bar -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="12" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Search" Width="100" Height="36"
                        Style="{StaticResource PrimaryButton}" Click="Search_Click"/>
                <Grid Margin="0,0,10,0">
                    <TextBox x:Name="QueryBox" Height="36"
                             VerticalContentAlignment="Center" Padding="10,0"
                             FontSize="13" Background="{StaticResource Panel2}"
                             BorderThickness="0"/>
                    <TextBlock x:Name="QueryPlaceholder"
                               Text="Search landlord by name..."
                               IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               Visibility="Visible"/>
                </Grid>
            </DockPanel>
        </Border>

        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="{StaticResource Danger}"
                   VerticalAlignment="Bottom" Margin="0,0,0,-8" FontSize="12"/>

        <!-- Main Content: Search Results + Portfolio -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Search Results Panel (Card list, not DataGrid) -->
            <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="14,12" BorderBrush="{StaticResource Border}"
                            BorderThickness="0,0,0,1">
                        <TextBlock x:Name="ResultsHeader" Text="All Landlords" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"/>
                    </Border>
                    <ListBox x:Name="LandlordsGrid"
                             Grid.Row="1" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource LlResultItem}"
                             SelectionChanged="LandlordsGrid_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Border Width="38" Height="38" CornerRadius="19"
                                            Background="{StaticResource AccentSoft}" Margin="0,0,12,0">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="18"
                                                   Foreground="{StaticResource Accent}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Name + Email -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Email}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Properties count badge -->
                                    <Border Grid.Column="2" CornerRadius="12" Padding="8,3"
                                            Background="{StaticResource Panel2}" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PropertiesCount}" FontSize="11" FontWeight="Bold"
                                                       Foreground="{StaticResource Text}"/>
                                            <TextBlock Text=" props" FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Portfolio Panel -->
            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Landlord Info Header -->
                    <Border x:Name="LandlordInfoPanel" Grid.Row="0"
                            Padding="20,16" BorderBrush="{StaticResource Border}"
                            BorderThickness="0,0,0,1" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar circle -->
                            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                                    Background="{StaticResource AccentSoft}" Margin="0,0,16,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="24"
                                           Foreground="{StaticResource Accent}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="LandlordNameText" FontSize="17" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}"/>
                                <TextBlock x:Name="LandlordEmailText" FontSize="12"
                                           Foreground="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                            </StackPanel>

                            <!-- Request New ID Button -->
                            <Button x:Name="RequestIdBtn" Grid.Column="2"
                                    Height="34" Padding="14,0"
                                    Style="{StaticResource LlBtn}"
                                    Background="{StaticResource WarningSoftBrush}" Foreground="#92400E"
                                    Click="RequestNewId_Click"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D7;" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Request New ID" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Placeholder when no landlord selected -->
                    <Border x:Name="NoSelectionPlaceholder" Grid.Row="1"
                            Padding="40,80" HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FD;" FontSize="44"
                                       Foreground="{StaticResource Border}"
                                       HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <TextBlock Text="Select a landlord to view their portfolio"
                                       Foreground="{StaticResource TextMuted}" FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Scrollable portfolio content with Expanders -->
                    <ScrollViewer x:Name="PortfolioScroll" Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed" Padding="16,12">

                        <StackPanel>

                            <!-- ═══════ PROPERTIES SECTION ═══════ -->
                            <Expander Style="{StaticResource SectionExpander}" IsExpanded="True">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="15"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Properties" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="PropsCountBadge" Text="" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Expander.Header>
                                <ItemsControl x:Name="PropsItems" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Panel2}" CornerRadius="12"
                                                    Padding="16,12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Address + Status -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Address}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Text}" TextWrapping="Wrap"/>
                                                        <!-- Status badge -->
                                                        <Border x:Name="psbadge" Grid.Column="1" CornerRadius="12" Padding="10,4"
                                                                Background="{StaticResource PendingSoftBrush}" VerticalAlignment="Top" Margin="10,0,0,0">
                                                            <TextBlock x:Name="pstxt" Text="{Binding SubmissionStatus}"
                                                                       FontSize="10" FontWeight="SemiBold" Foreground="#C2410C"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Action buttons -->
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                        <Button Content="View Details" Height="30" Padding="12,0"
                                                                Style="{StaticResource LlBtn}"
                                                                Background="{StaticResource AccentSoft}"
                                                                Foreground="{StaticResource Accent}"
                                                                Click="ViewPropertyDetails_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Border.Resources>
                                                    <Style TargetType="Border">
                                                        <!-- Status badge triggers need DataTemplate.Triggers -->
                                                    </Style>
                                                </Border.Resources>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SubmissionStatus}" Value="Approved">
                                                    <Setter TargetName="psbadge" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                    <Setter TargetName="pstxt"  Property="Foreground" Value="#15803D"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SubmissionStatus}" Value="Rejected">
                                                    <Setter TargetName="psbadge" Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                                    <Setter TargetName="pstxt"  Property="Foreground" Value="#DC2626"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>

                            <!-- ═══════ LEASES SECTION ═══════ -->
                            <Expander Style="{StaticResource SectionExpander}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="15"
                                                   Foreground="{StaticResource Success}" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Leases" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LeasesCountBadge" Text="" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Expander.Header>
                                <ItemsControl x:Name="LeasesItems" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Panel2}" CornerRadius="12"
                                                    Padding="16,12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="6"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Address}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Text}" TextWrapping="Wrap"/>
                                                        <!-- Lease status badge -->
                                                        <Border x:Name="leasebadge" Grid.Column="1" CornerRadius="12" Padding="10,4"
                                                                Background="{StaticResource SuccessSoft}" VerticalAlignment="Top"
                                                                Margin="10,0,0,0">
                                                            <TextBlock x:Name="leasetxt" Text="{Binding LeaseStatus}"
                                                                       FontSize="10" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Success}"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Lease period + tenant info -->
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                            <TextBlock.Text>
                                                                <Binding Path="LeaseStartDate" StringFormat="From: MMM dd\, yyyy"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Text="  —  " FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                            <TextBlock.Text>
                                                                <Binding Path="LeaseEndDate" StringFormat="To: MMM dd\, yyyy"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Text="  |  " FontSize="11" Foreground="{StaticResource Border}"/>
                                                        <TextBlock Text="{Binding TenantEmail}" FontSize="11"
                                                                   Foreground="{StaticResource Accent}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding LeaseStatus}" Value="Expired">
                                                    <Setter TargetName="leasebadge" Property="Background" Value="{StaticResource Panel2}"/>
                                                    <Setter TargetName="leasetxt"  Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LeaseStatus}" Value="Terminated">
                                                    <Setter TargetName="leasebadge" Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                                    <Setter TargetName="leasetxt"  Property="Foreground" Value="{StaticResource Danger}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

        <TextBlock x:Name="EmptyState" Text="No landlords found." FontSize="14" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Grid.Row="4"/>

        <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed" Grid.RowSpan="5" Panel.ZIndex="100">
            <TextBlock Text="Loading..." FontSize="14" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>

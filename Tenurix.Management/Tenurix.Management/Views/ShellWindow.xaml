<Window x:Class="Tenurix.Management.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tenurix Management"
        Width="1200" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource Panel2}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Branding/tenurix_logoB.png"
                           Height="36"
                           Stretch="Uniform"/>
                    <TextBlock Text="Tenurix" Margin="10,0,0,0"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="2">
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource NavRadio}" GroupName="Nav"
                                 Content="Dashboard" Tag="" Click="Dashboard_Click"/>
                    <RadioButton x:Name="NavProps" Style="{StaticResource NavRadio}" GroupName="Nav"
                                 Content="Property Submissions" Tag="" Click="Props_Click"/>
                    <RadioButton x:Name="NavApps" Style="{StaticResource NavRadio}" GroupName="Nav"
                                 Content="Lease Applications" Tag="" Click="Apps_Click"/>
                    <RadioButton x:Name="NavListings" Style="{StaticResource NavRadio}" GroupName="Nav"
                                 Content="Listings" Tag="" Click="Listings_Click"/>
                    <RadioButton x:Name="NavChangePw" Style="{StaticResource NavRadio}" GroupName="Nav"
                                 Content="Change Password" Tag="" Click="ChangePassword_Click"/>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="3" Margin="0,18,0,0">
                    <Separator Margin="0,0,0,12"/>
                    <RadioButton x:Name="NavLogout" Style="{StaticResource NavRadio}" GroupName="Nav"
                                 Content="Logout" Tag="" Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main area -->
        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top strip -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock Text="Tenurix Management"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Initials badge = Profile button -->
                    <Button Click="MenuProfile_Click" ToolTip="My Profile"
                            Cursor="Hand" Background="Transparent" BorderThickness="0"
                            Padding="0" Margin="0,0,12,0">
                        <Border Width="38" Height="38" CornerRadius="19"
                                Background="{StaticResource Accent}">
                            <TextBlock x:Name="UserInitialsText"
                                       Text="AM"
                                       Foreground="#FFFFFF"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Button>

                    <!-- Logout button (red) -->
                    <Button Click="MenuLogout_Click" ToolTip="Logout"
                            Cursor="Hand" Background="#ef4444" BorderThickness="0"
                            Padding="12,7" Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="Logout" FontSize="13" FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Button>
                </StackPanel>
            </DockPanel>

            <!-- Welcome card -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="18">
                <StackPanel Orientation="Horizontal">

                    <Border Width="54" Height="54" CornerRadius="27"
                            Background="{StaticResource AccentSoft}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            Margin="0,0,14,0">
                        <Grid>
                            <Image x:Name="HeaderAvatar" Stretch="UniformToFill"/>
                            <TextBlock x:Name="HeaderAvatarFallback"
                                       Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMuted}"/>
                        </Grid>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="UserText" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:Name="RoleText" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Content card -->
            <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="24">
                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </Border>
        </Grid>
    </Grid>
</Window>

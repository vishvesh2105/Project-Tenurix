<Page x:Class="Tenurix.Management.Views.Pages.EmployeesPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="EmpBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel>
            <TextBlock Text="Employees" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Text="Manage team members, reset passwords, and view details."
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Info Banner -->
        <Border Grid.Row="2" Background="{StaticResource Panel2}" CornerRadius="12" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="16"
                           Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Managers can create TeamLead and Staff accounts, and reset passwords for team members."
                           FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Card List -->
        <Border Grid.Row="4" Background="{StaticResource Panel}" CornerRadius="14" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="EmployeeGrid">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Panel2}" CornerRadius="12"
                                    Padding="16,14" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Border Width="42" Height="42" CornerRadius="21"
                                            Background="{StaticResource AccentSoft}" Margin="0,0,14,0"
                                            VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="20"
                                                   Foreground="{StaticResource Accent}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Name + Email -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}"/>
                                        <TextBlock Text="{Binding Email}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Role Badge -->
                                    <Border x:Name="rbadge" Grid.Column="2" CornerRadius="12" Padding="10,4"
                                            Background="{StaticResource AccentSoft}" VerticalAlignment="Center"
                                            Margin="10,0,0,0">
                                        <TextBlock x:Name="rtxt" Text="{Binding RoleName}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Accent}"/>
                                    </Border>

                                    <!-- Status Badge -->
                                    <Border x:Name="statbadge" Grid.Column="3" CornerRadius="12" Padding="10,4"
                                            Background="{StaticResource SuccessSoft}" VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                        <TextBlock x:Name="stattxt" Text="{Binding Status}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Success}"/>
                                    </Border>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <Button Content="Reset Password"
                                                Height="32" Padding="10,0" Margin="0,0,8,0"
                                                Style="{StaticResource EmpBtn}"
                                                Background="{StaticResource Panel}"
                                                Foreground="{StaticResource Text}"
                                                CommandParameter="{Binding UserId}"
                                                Click="ResetPassword_Click"/>
                                        <Button Content="View"
                                                Height="32" Width="60"
                                                Style="{StaticResource EmpBtn}"
                                                Background="{StaticResource AccentSoft}"
                                                Foreground="{StaticResource Accent}"
                                                CommandParameter="{Binding UserId}"
                                                Click="ViewEmployee_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RoleName}" Value="Manager">
                                    <Setter TargetName="rbadge" Property="Background" Value="#FEF2F2"/>
                                    <Setter TargetName="rtxt"  Property="Foreground" Value="#DC2626"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RoleName}" Value="TeamLead">
                                    <Setter TargetName="rbadge" Property="Background" Value="#FFFBEB"/>
                                    <Setter TargetName="rtxt"  Property="Foreground" Value="#D97706"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RoleName}" Value="Staff">
                                    <Setter TargetName="rbadge" Property="Background" Value="#F0FDF4"/>
                                    <Setter TargetName="rtxt"  Property="Foreground" Value="#15803D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                    <Setter TargetName="statbadge" Property="Background" Value="{StaticResource Panel2}"/>
                                    <Setter TargetName="stattxt"  Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Bottom Actions -->
        <Border Grid.Row="5" Background="{StaticResource Panel}" CornerRadius="12" Padding="16,12" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetPwBtn"
                        Content="Reset Password (Selected)"
                        Height="38" Padding="16,0"
                        Margin="0,0,10,0" Visibility="Collapsed"
                        Style="{StaticResource EmpBtn}"
                        Background="{StaticResource Panel2}"
                        Foreground="{StaticResource Text}"
                        Click="ResetPassword_Click"/>
                <Button x:Name="CreateBtn"
                        Content="+ Create Employee"
                        Height="38" Padding="16,0"
                        Style="{StaticResource EmpBtn}"
                        Background="{StaticResource Accent}"
                        Foreground="White"
                        Click="Create_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>

<Window x:Class="Tenurix.Management.Views.Windows.IssueDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Issue Detail"
        MinWidth="680" MinHeight="550" Width="860" Height="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="DtlLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DtlValue" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Foreground"  Value="{StaticResource Text}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource Panel}"/>
            <Setter Property="CornerRadius"   Value="14"/>
            <Setter Property="Padding"        Value="18"/>
            <Setter Property="Margin"         Value="0,0,0,14"/>
        </Style>
        <Style x:Key="ActBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Issue Detail" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource Text}"/>
                <TextBlock Text="Full details and actions for this issue."
                           FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border x:Name="StatusBadge" Grid.Column="1" CornerRadius="8" Padding="14,6"
                    Background="#1D4ED8" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="" Foreground="White"
                           FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMuted}"
                    Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0"
                    Click="CloseButton_Click" ToolTip="Close" Padding="6" Panel.ZIndex="10"
                    Grid.ColumnSpan="2"/>
        </Grid>

        <!-- Body -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Filed By + Date -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="46" Height="46" CornerRadius="23"
                                Background="{StaticResource DangerSoftBrush}" Margin="0,0,16,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="22"
                                       Foreground="{StaticResource Danger}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="FILED BY (TENANT)" Style="{StaticResource DtlLabel}"/>
                            <TextBlock x:Name="FiledByText" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text}"/>
                            <TextBlock x:Name="FiledByEmailText" FontSize="12"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="DATE FILED" Style="{StaticResource DtlLabel}"/>
                            <TextBlock x:Name="DateText" Style="{StaticResource DtlValue}" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Property + Landlord -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="PROPERTY ADDRESS" Style="{StaticResource DtlLabel}"/>
                            <TextBlock x:Name="PropertyText" Style="{StaticResource DtlValue}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="LANDLORD" Style="{StaticResource DtlLabel}"/>
                            <TextBlock x:Name="LandlordNameText" Style="{StaticResource DtlValue}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LandlordText" FontSize="12"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Issue Type + Description -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ISSUE TYPE" Style="{StaticResource DtlLabel}"/>
                        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}" Margin="0,0,0,16"/>

                        <TextBlock Text="DESCRIPTION" Style="{StaticResource DtlLabel}"/>
                        <TextBlock x:Name="DescText" Style="{StaticResource DtlValue}"
                                   FontSize="13" LineHeight="22"
                                   Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Attached Image -->
                <Border x:Name="ImageCard" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ATTACHED IMAGE" Style="{StaticResource DtlLabel}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <Button x:Name="ViewImageButton" Grid.Column="1"
                                    Content="Open Full Size"
                                    Style="{StaticResource ActBtn}"
                                    Background="{StaticResource AccentSoft}"
                                    Foreground="{StaticResource Accent}"
                                    Height="32" Padding="14,0" FontSize="12"
                                    Click="ViewImage_Click"/>
                        </Grid>

                        <Border CornerRadius="10" Background="#0F172A" ClipToBounds="True">
                            <Grid>
                                <TextBlock x:Name="ImageStatusText" Text="Loading image..."
                                           Foreground="#94A3B8" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="20"/>
                                <Image x:Name="AttachedImage"
                                       MaxHeight="380"
                                       Stretch="Uniform"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Internal Note -->
                <Border x:Name="NoteBorder" Style="{StaticResource Card}" Visibility="Collapsed"
                        Background="#FFFBEB">
                    <StackPanel>
                        <TextBlock Text="INTERNAL NOTE" Style="{StaticResource DtlLabel}"
                                   Foreground="#D97706"/>
                        <TextBlock x:Name="NoteText" TextWrapping="Wrap" FontSize="13"
                                   Foreground="{StaticResource Text}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Footer -->
        <Border Grid.Row="3" Background="{StaticResource Panel}" CornerRadius="12"
                Padding="16,14" Margin="0,0,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Mark In Progress" Width="160"
                        Style="{StaticResource ActBtn}"
                        Background="#FFFBEB" Foreground="#D97706"
                        Padding="14,0" Click="InProgress_Click"/>
                <Button Content="Mark Resolved" Width="150" Margin="10,0,0,0"
                        Style="{StaticResource ActBtn}"
                        Background="{StaticResource SuccessSoft}" Foreground="{StaticResource Success}"
                        Padding="14,0" Click="Resolved_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

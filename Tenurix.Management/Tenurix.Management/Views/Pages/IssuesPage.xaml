<Page x:Class="Tenurix.Management.Views.Pages.IssuesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="IssBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel>
            <TextBlock Text="Issues" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Text="Track and resolve maintenance issues filed by tenants."
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="12" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Refresh" Width="90" Height="36"
                        Click="Refresh_Click"
                        Style="{StaticResource IssBtn}" Background="{StaticResource Panel2}"
                        Foreground="{StaticResource Text}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filter by status:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,10,0"/>
                    <ComboBox x:Name="StatusFilter" Width="160" Height="36"
                              SelectionChanged="StatusFilter_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Submitted" IsSelected="True"/>
                        <ComboBoxItem Content="InProgress"/>
                        <ComboBoxItem Content="Resolved"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Card List -->
        <Border Grid.Row="4" Background="{StaticResource Panel}" CornerRadius="14" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="Grid">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Panel2}" CornerRadius="12"
                                    Padding="16,14" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Issue type + Status badge -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding IssueType}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text}"/>
                                            <TextBlock Text="{Binding PropertyAddress}" FontSize="12"
                                                       Foreground="{StaticResource TextMuted}" Margin="0,3,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border x:Name="sbadge" Grid.Column="1" CornerRadius="12" Padding="10,4"
                                                Background="{StaticResource InfoSoftBrush}" VerticalAlignment="Top" Margin="10,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="sicon" FontFamily="Segoe MDL2 Assets" Text="&#xE823;" FontSize="10"
                                                           Foreground="#1D4ED8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock x:Name="stxt" Text="{Binding Status}"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Row 2: Description + Reported by + Date -->
                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{StaticResource Text}" TextWrapping="Wrap"
                                                   MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Reported by: " FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding ReportedBy}" FontSize="11"
                                                       Foreground="{StaticResource Accent}"/>
                                            <TextBlock Text="  |  " FontSize="11" Foreground="{StaticResource Border}"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                <TextBlock.Text>
                                                    <Binding Path="CreatedAt" StringFormat="MMM dd\, yyyy"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Row 3: Action buttons -->
                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        <Button Content="View Details" Click="ViewDetails_Click"
                                                Height="32" Padding="12,0" Margin="0,0,8,0"
                                                Style="{StaticResource IssBtn}"
                                                Background="{StaticResource AccentSoft}"
                                                Foreground="{StaticResource Accent}"/>
                                        <Button Content="Mark In Progress" Tag="{Binding}" Click="MarkInProgress_Click"
                                                Height="32" Padding="12,0" Margin="0,0,8,0"
                                                Style="{StaticResource IssBtn}"
                                                Background="#FFFBEB"
                                                Foreground="#D97706"/>
                                        <Button Content="Mark Resolved" Tag="{Binding}" Click="MarkResolved_Click"
                                                Height="32" Padding="12,0"
                                                Style="{StaticResource IssBtn}"
                                                Background="{StaticResource SuccessSoft}"
                                                Foreground="{StaticResource Success}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                    <Setter TargetName="sbadge" Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="#D97706"/>
                                    <Setter TargetName="sicon" Property="Foreground" Value="#D97706"/>
                                    <Setter TargetName="sicon" Property="Text" Value="&#xE769;"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Resolved">
                                    <Setter TargetName="sbadge" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="#15803D"/>
                                    <Setter TargetName="sicon" Property="Foreground" Value="#15803D"/>
                                    <Setter TargetName="sicon" Property="Text" Value="&#xE73E;"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock x:Name="ResultCount" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" Grid.Row="5"/>

        <TextBlock x:Name="EmptyState" Text="No issues reported." FontSize="14" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed" Grid.Row="4"/>

        <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed" Grid.RowSpan="6" Panel.ZIndex="100">
            <TextBlock Text="Loading..." FontSize="14" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>

<Window x:Class="Tenurix.Management.Views.Windows.EmployeeProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Profile"
        Width="1020" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="EpColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="Background"      Value="{StaticResource Panel2}"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="EpCell" TargetType="DataGridCell">
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        </Style>
        <Style x:Key="EpRow" TargetType="DataGridRow">
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Background"      Value="{StaticResource Panel}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Panel2}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EpBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Height"      Value="34"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource Panel}" CornerRadius="14" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="48" Height="48" CornerRadius="24"
                        Background="{StaticResource AccentSoft}" Margin="0,0,16,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="24"
                               Foreground="{StaticResource Accent}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding HeaderTitle}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock Text="{Binding HeaderSubtitle}" FontSize="12"
                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Calendar Panel -->
            <Border Background="{StaticResource Panel}" CornerRadius="14" Padding="14">
                <StackPanel>
                    <TextBlock Text="Attendance Calendar" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource Text}" Margin="0,0,0,10"/>
                    <Calendar x:Name="Cal" SelectedDatesChanged="Cal_SelectedDatesChanged"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a day to view shift details."
                               Foreground="{StaticResource TextMuted}" FontSize="11"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Day Details Panel -->
            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="14" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding SelectedDayTitle}" FontWeight="SemiBold" FontSize="16"
                               Foreground="{StaticResource Text}"/>

                    <!-- Summary Cards -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Border Background="{StaticResource Panel2}" CornerRadius="10" Padding="14,10" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="WORKED" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding WorkedText}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource Panel2}" CornerRadius="10" Padding="14,10" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="BREAKS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding BreaksText}" FontSize="18" FontWeight="Bold"
                                           Foreground="#D97706"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource Panel2}" CornerRadius="10" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="SHORT BREAKS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding ShortBreakCountText}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource Success}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Blocks Grid -->
                    <DataGrid Grid.Row="4" x:Name="BlocksGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              ColumnHeaderStyle="{StaticResource EpColHeader}"
                              CellStyle="{StaticResource EpCell}"
                              RowStyle="{StaticResource EpRow}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Border}"
                              BorderThickness="0"
                              Background="{StaticResource Panel}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="BREAK TYPE" Binding="{Binding BreakType}" Width="120"/>
                            <DataGridTextColumn Header="START" Binding="{Binding StartLocal}" Width="*"/>
                            <DataGridTextColumn Header="END" Binding="{Binding EndLocal}" Width="*"/>
                            <DataGridTextColumn Header="DURATION" Binding="{Binding DurationText}" Width="100"/>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Void" Height="28" Width="60"
                                                Style="{StaticResource EpBtn}"
                                                Background="{StaticResource DangerSoft}"
                                                Foreground="{StaticResource Danger}"
                                                CommandParameter="{Binding}"
                                                Click="Void_Click"
                                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=CanEditAttendanceVisibility}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Admin Punch -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Admin Punch" Width="130"
                                Style="{StaticResource EpBtn}"
                                Background="{StaticResource AccentSoft}" Foreground="{StaticResource Accent}"
                                Padding="10,0"
                                Click="AdminPunch_Click"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=CanEditAttendanceVisibility}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Tenurix.Management.Views.Windows.EmployeeProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Details"
        Width="820" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Margin"     Value="0,0,0,16"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="PropColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="Background"      Value="{StaticResource Panel2}"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="PropCell" TargetType="DataGridCell">
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        </Style>
        <Style x:Key="PropRow" TargetType="DataGridRow">
            <Setter Property="Height"     Value="44"/>
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Panel2}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource Panel}" CornerRadius="14" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="48" Height="48" CornerRadius="24"
                        Background="{StaticResource AccentSoft}" Margin="0,0,16,0">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="24"
                               Foreground="{StaticResource Accent}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderName" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock x:Name="HeaderSub" FontSize="12"
                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Status badge -->
                <Border x:Name="StatusBadge" Grid.Column="2" CornerRadius="12" Padding="12,6"
                        Background="{StaticResource SuccessSoft}" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Success}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Employee Info Panel -->
            <Border Background="{StaticResource Panel}" CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Employee Information" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource Text}" Margin="0,0,0,16"/>

                    <TextBlock Text="FULL NAME" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="DetailName" Style="{StaticResource DetailValue}"/>

                    <TextBlock Text="EMAIL" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="DetailEmail" Style="{StaticResource DetailValue}"/>

                    <TextBlock Text="MOBILE NUMBER" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="DetailPhone" Style="{StaticResource DetailValue}"/>

                    <TextBlock Text="ADDRESS" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="DetailAddress" Style="{StaticResource DetailValue}"/>

                    <TextBlock Text="POSITION" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="DetailRole" Style="{StaticResource DetailValue}"/>
                </StackPanel>
            </Border>

            <!-- Assigned Properties Panel -->
            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="14" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Assigned Properties" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource Text}"/>

                    <TextBlock x:Name="PropCountText" Grid.Row="2" FontSize="12"
                               Foreground="{StaticResource TextMuted}"/>

                    <DataGrid Grid.Row="4" x:Name="PropertiesGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              ColumnHeaderStyle="{StaticResource PropColHeader}"
                              CellStyle="{StaticResource PropCell}"
                              RowStyle="{StaticResource PropRow}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Border}"
                              BorderThickness="0"
                              Background="{StaticResource Panel}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ADDRESS" Binding="{Binding AddressLine1}" Width="*"/>
                            <DataGridTextColumn Header="CITY" Binding="{Binding City}" Width="100"/>
                            <DataGridTextColumn Header="PROVINCE" Binding="{Binding Province}" Width="80"/>
                            <DataGridTextColumn Header="POSTAL CODE" Binding="{Binding PostalCode}" Width="100"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding PropertyType}" Width="100"/>
                            <DataGridTextColumn Header="STATUS" Binding="{Binding SubmissionStatus}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

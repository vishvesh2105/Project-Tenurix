<Window x:Class="Tenurix.Management.Views.Windows.LeaseEditSendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit &amp; Send Lease Agreement"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel>
            <TextBlock Text="Edit &amp; Send Lease Agreement" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock x:Name="SubtitleText"
                       Text="Review and update lease terms before sending to the tenant."
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Info card -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="TENANT" Style="{StaticResource FieldLabel}"/>
                    <TextBlock x:Name="TenantText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TenantEmailText" FontSize="12"
                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="PROPERTY" Style="{StaticResource FieldLabel}"/>
                    <TextBlock x:Name="PropertyText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Edit form -->
        <Border Grid.Row="4" Background="{StaticResource Panel}" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="LEASE TERMS" Style="{StaticResource FieldLabel}" Margin="0,0,0,12"/>

                <!-- Rent Amount -->
                <TextBlock Text="MONTHLY RENT (CAD)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="RentBox" Height="40" Padding="12,0"
                         VerticalContentAlignment="Center" FontSize="14"
                         Margin="0,0,0,14"/>

                <!-- Dates row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="LEASE START DATE" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="StartDatePicker" Height="40" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LEASE END DATE" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="EndDatePicker" Height="40" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Status message -->
                <TextBlock x:Name="StatusMsg" FontSize="12" Margin="0,14,0,0"
                           Foreground="{StaticResource Danger}" Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Footer buttons -->
        <Border Grid.Row="5" Background="{StaticResource Panel}" CornerRadius="12"
                Padding="16,12" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Padding="16,0" Margin="0,0,10,0"
                        Style="{StaticResource ActionBtn}"
                        Background="{StaticResource Panel2}"
                        Foreground="{StaticResource Text}"
                        Click="Cancel_Click"/>
                <Button x:Name="SaveBtn" Content="Save &amp; Regenerate PDF" Width="190" Padding="16,0" Margin="0,0,10,0"
                        Style="{StaticResource ActionBtn}"
                        Background="{StaticResource AccentSoft}"
                        Foreground="{StaticResource Accent}"
                        Click="Save_Click"/>
                <Button x:Name="SendBtn" Content="Send to Tenant" Width="150" Padding="16,0"
                        Style="{StaticResource ActionBtn}"
                        Background="{StaticResource SuccessSoft}"
                        Foreground="{StaticResource Success}"
                        Click="Send_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>

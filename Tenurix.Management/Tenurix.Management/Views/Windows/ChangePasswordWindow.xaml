<Window x:Class="Tenurix.Management.Views.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="480" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <Style x:Key="PwdLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
        <Style x:Key="PwdInput" TargetType="PasswordBox">
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Padding"     Value="12,0"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Background"  Value="{StaticResource Panel2}"/>
            <Setter Property="Foreground"  Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"      Value="0,0,0,16"/>
        </Style>
        <Style x:Key="RBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="{StaticResource Panel}" CornerRadius="16" Padding="24">
            <StackPanel>
                <TextBlock Text="Change Password" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource Text}"/>
                <TextBlock Text="Enter your current password and choose a new one."
                           FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,24"/>

                <TextBlock Text="CURRENT PASSWORD" Style="{StaticResource PwdLabel}"/>
                <PasswordBox x:Name="CurrentPwdBox" Style="{StaticResource PwdInput}"/>

                <TextBlock Text="NEW PASSWORD" Style="{StaticResource PwdLabel}"/>
                <PasswordBox x:Name="NewPwdBox" Style="{StaticResource PwdInput}"/>

                <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource PwdLabel}"/>
                <PasswordBox x:Name="ConfirmPwdBox" Style="{StaticResource PwdInput}"/>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancel"
                            Style="{StaticResource RBtn}"
                            Background="{StaticResource Panel2}" Foreground="{StaticResource Text}"
                            Click="Cancel_Click"/>
                    <Button Grid.Column="2" Content="Update Password"
                            Style="{StaticResource RBtn}"
                            Background="{StaticResource Accent}" Foreground="White"
                            Click="UpdatePassword_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>

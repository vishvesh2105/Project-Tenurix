<Page x:Class="Tenurix.Management.Views.Pages.ListingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="LstBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel>
            <TextBlock Text="Listings" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Text="All property listings on the platform."
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Search + Filter Toolbar -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="12" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Refresh" Width="90" Height="36"
                        Margin="10,0,0,0" Click="Refresh_Click"
                        Style="{StaticResource LstBtn}" Background="{StaticResource Panel2}"
                        Foreground="{StaticResource Text}"/>
                <Button DockPanel.Dock="Right" Content="Search" Width="90" Height="36"
                        Style="{StaticResource PrimaryButton}" Click="Search_Click"/>

                <!-- Status filter -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock Text="Status:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,8,0"/>
                    <ComboBox x:Name="StatusFilter" Width="130" Height="36"
                              SelectionChanged="StatusFilter_SelectionChanged">
                        <ComboBoxItem Content="Active" IsSelected="True"/>
                        <ComboBoxItem Content="Inactive"/>
                        <ComboBoxItem Content="All"/>
                    </ComboBox>
                </StackPanel>

                <TextBox x:Name="QueryBox" Height="36" Margin="0,0,10,0"
                         VerticalContentAlignment="Center" Padding="12,0"
                         FontSize="13"/>
            </DockPanel>
        </Border>

        <!-- Error -->
        <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="{StaticResource Danger}"
                   VerticalAlignment="Top" Margin="0,0,0,8" FontSize="12"/>

        <!-- Card List -->
        <Border Grid.Row="4" Background="{StaticResource Panel}" CornerRadius="14" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListingsGrid">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Panel2}" CornerRadius="12"
                                    Padding="16,14" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Address + Date -->
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Address}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" TextWrapping="Wrap"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"
                                                   Text="{Binding CreatedAt, StringFormat='Created: {0:MMM dd, yyyy}'}"/>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border x:Name="sbadge" Grid.Column="1" CornerRadius="12" Padding="10,4"
                                            Background="{StaticResource SuccessSoft}"
                                            VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock x:Name="stxt" Text="{Binding ListingStatus}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Success}"/>
                                    </Border>

                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                        <Button Content="View Details" Tag="{Binding}"
                                                Click="View_Click" Height="34" Padding="14,0"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource LstBtn}"
                                                Background="{StaticResource AccentSoft}"
                                                Foreground="{StaticResource Accent}"/>
                                        <Button x:Name="toggleBtn" Tag="{Binding}"
                                                Content="Deactivate"
                                                Click="ToggleStatus_Click" Height="34" Padding="14,0"
                                                Style="{StaticResource LstBtn}"
                                                Background="#FEF2F2" Foreground="#DC2626"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding ListingStatus}" Value="Inactive">
                                    <Setter TargetName="sbadge" Property="Background" Value="{StaticResource Panel2}"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="{StaticResource TextMuted}"/>
                                    <Setter TargetName="toggleBtn" Property="Content" Value="Activate"/>
                                    <Setter TargetName="toggleBtn" Property="Background" Value="#F0FDF4"/>
                                    <Setter TargetName="toggleBtn" Property="Foreground" Value="#15803D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ListingStatus}" Value="Closed">
                                    <Setter TargetName="sbadge" Property="Background" Value="#FEF2F2"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="{StaticResource Danger}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ListingStatus}" Value="Pending">
                                    <Setter TargetName="sbadge" Property="Background" Value="#FFF7ED"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="#C2410C"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer / Count -->
        <Border Grid.Row="5" Padding="0,12,0,0">
            <TextBlock x:Name="CountText"
                       Text="Showing 0 listings"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12"/>
        </Border>

    </Grid>
</Page>

<Page x:Class="Tenurix.Management.Views.Pages.LeaseApplicationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="LaBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel>
            <TextBlock Text="Lease Applications" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Text}"/>
            <TextBlock Text="Review and approve or reject tenant lease applications."
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="12" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Refresh" Width="90" Height="36"
                        Click="Refresh_Click"
                        Style="{StaticResource LaBtn}" Background="{StaticResource Panel2}"
                        Foreground="{StaticResource Text}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filter by status:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,10,0"/>
                    <ComboBox x:Name="StatusFilter" Width="160" Height="36"
                              SelectionChanged="StatusFilter_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Pending" IsSelected="True"/>
                        <ComboBoxItem Content="Approved"/>
                        <ComboBoxItem Content="Rejected"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Card List -->
        <Border Grid.Row="4" Background="{StaticResource Panel}" CornerRadius="14" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="Grid">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Panel2}" CornerRadius="12"
                                    Padding="16,14" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Applicant name + Status badge -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ApplicantName}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text}"/>
                                            <TextBlock Text="{Binding ApplicantEmail}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border x:Name="sbadge" Grid.Column="1" CornerRadius="12" Padding="10,4"
                                                Background="#FFF7ED" VerticalAlignment="Top">
                                            <TextBlock x:Name="stxt" Text="{Binding Status}"
                                                       FontSize="10" FontWeight="SemiBold" Foreground="#C2410C"/>
                                        </Border>
                                    </Grid>

                                    <!-- Row 2: Property + Lease dates -->
                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="{Binding PropertyAddress}" FontSize="13"
                                                   Foreground="{StaticResource Text}" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}"
                                                       Text="{Binding LeaseStartDate, StringFormat='Start: {0:MMM dd, yyyy}'}"/>
                                            <TextBlock Text="  —  " FontSize="11" Foreground="{StaticResource Border}"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}"
                                                       Text="{Binding LeaseEndDate, StringFormat='End: {0:MMM dd, yyyy}'}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Row 3: Action buttons -->
                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        <Button Content="View Details" Tag="{Binding}" Click="View_Click"
                                                Height="32" Padding="12,0" Margin="0,0,8,0"
                                                Style="{StaticResource LaBtn}"
                                                Background="{StaticResource AccentSoft}"
                                                Foreground="{StaticResource Accent}"/>
                                        <Button Content="Approve" Tag="{Binding}" Click="Approve_Click"
                                                Height="32" Padding="12,0" Margin="0,0,8,0"
                                                Style="{StaticResource LaBtn}"
                                                Background="{StaticResource SuccessSoft}"
                                                Foreground="{StaticResource Success}"/>
                                        <Button Content="Reject" Tag="{Binding}" Click="Reject_Click"
                                                Height="32" Padding="12,0"
                                                Style="{StaticResource LaBtn}"
                                                Background="{StaticResource DangerSoft}"
                                                Foreground="{StaticResource Danger}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Approved">
                                    <Setter TargetName="sbadge" Property="Background" Value="#F0FDF4"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="#15803D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                    <Setter TargetName="sbadge" Property="Background" Value="#FEF2F2"/>
                                    <Setter TargetName="stxt"  Property="Foreground" Value="#DC2626"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
